  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "astro": "^7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.13.3",
    "jsdom": "^27.4.0",
    "typescript": "^5.9.3",
    "vite": "8.1.5",
    "vitest": "^4.1.0",
    "workbox-build": "^7.4.1",
    "wrangler": "^4.113.0"
  }
