---
import '../styles/app.css'
---
<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#143b63" />
    <title>租賃住宅管理人員題庫</title>
  </head>
  <body>
    <main id="app" aria-live="polite"></main>
    <script>
      const root = document.querySelector<HTMLElement>('#app')!
      const appBase = import.meta.env.BASE_URL.replace(/\/+$/, '')
      const practicePath = `${appBase}/practice/`
      const renderChoice = () => {
        root.innerHTML = `<section class="question-bank-choice" aria-labelledby="question-bank-heading"><p class="eyebrow">租賃住宅管理人員題庫</p><h1 id="question-bank-heading">選擇題庫</h1><p>請選擇要使用的題庫版本。之後可隨時由頁首返回更換。</p><div class="question-bank-actions"><button type="button" class="button" data-question-bank="withLaw">有詳解題庫</button><button type="button" class="button secondary-button" data-question-bank="withoutLaw">只有答案題庫</button></div></section>`
        root.querySelectorAll<HTMLButtonElement>('[data-question-bank]').forEach((button) => {
          button.addEventListener('click', () => {
            sessionStorage.setItem('rent-exam-question-bank-v1', button.dataset.questionBank!)
            window.location.assign(practicePath)
          })
        })
      }
      renderChoice()
    </script>
  </body>
</html>
